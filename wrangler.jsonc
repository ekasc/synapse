{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "synapse",
	"compatibility_date": "2026-06-10",
	"compatibility_flags": ["nodejs_compat", "nodejs_als"],
	"main": ".svelte-kit/cloudflare/_worker.js",
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	"r2_buckets": [
		{
			"binding": "MATERIALS",
			"bucket_name": "synapse-materials"
		}
	],
	// Weekly digest push: Mondays 15:00 UTC (07:00 PT). The scheduled handler
	// in worker.js calls /api/weekly-push/run with WEEKLY_PUSH_SECRET.
	"triggers": {
		"crons": ["0 15 * * 1"]
	},
	"workers_dev": true,
	"preview_urls": true,
	"vars": {
		"DATABASE_URL": "",
		"OPENROUTER_API_KEY": "",
		"OPENROUTER_MODEL": "",
		"COURSE_RESEARCH_SEARCH_MODEL": "deepseek/deepseek-v4-flash",
		"COURSE_RESEARCH_SYNTHESIS_MODEL": "deepseek/deepseek-v4-pro",
		"COURSE_RESEARCH_MAX_ESTIMATED_COST_USD": "0.10",
		"COURSE_RESEARCH_MAX_JOBS_PER_DAY": "20",
		"COURSE_RESEARCH_MAX_JOBS_PER_IP_PER_DAY": "20",
		"COURSE_RESEARCH_MAX_ACTIVE_JOBS": "3",
		"COURSE_RESEARCH_MIN_REFRESH_AGE_HOURS": "6",
		// Web Push (weekly digest). VAPID_PUBLIC_KEY is public; set
		// VAPID_PRIVATE_KEY and WEEKLY_PUSH_SECRET with `wrangler secret put`
		// (or .dev.vars locally). Generate keys: node scripts/generate-vapid-keys.mjs
		"VAPID_PUBLIC_KEY": "",
		"VAPID_SUBJECT": "mailto:team@synapse.study"
	},
	"d1_databases": [
		{
			"binding": "BRIEF_DB",
			"database_name": "synapse-briefs",
			"database_id": "08029d46-ff0a-41d9-bed3-5e837620170e",
			"migrations_dir": "migrations"
		}
	]
}
