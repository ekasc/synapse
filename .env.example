# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:***@host:port/db-name"

# AI syllabus extraction
OPENROUTER_API_KEY="sk-or-...-key"
OPENROUTER_MODEL="deepseek/deepseek-v4-flash"
OPENROUTER_VISION_MODEL="openai/gpt-4o-mini"

# Course Intelligence Brief server policy (not client-selectable)
COURSE_RESEARCH_SEARCH_MODEL="deepseek/deepseek-v4-flash"
COURSE_RESEARCH_SYNTHESIS_MODEL="deepseek/deepseek-v4-pro"
COURSE_RESEARCH_SEARCH_PROVIDER="StreamLake"
COURSE_RESEARCH_SYNTHESIS_PROVIDER="DigitalOcean"
COURSE_RESEARCH_MAX_ESTIMATED_COST_USD="0.10"
COURSE_RESEARCH_MAX_JOBS_PER_DAY="20"
COURSE_RESEARCH_MAX_ACTIVE_JOBS="3"
COURSE_RESEARCH_MIN_REFRESH_AGE_HOURS="6"

# Google Calendar OAuth
# Create credentials at https://console.cloud.google.com/apis/credentials (OAuth 2.0 Web Application)
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
# The callback URL registered in Google Cloud Console — must match EXACTLY
# For local dev: http://localhost:5173/api/calendar/google/callback
# For production: https://synapse.yourdomain.dev/api/calendar/google/callback
GOOGLE_REDIRECT_URI="http://localhost:5173/api/calendar/google/callback"

# Weekly digest push (Web Push / VAPID, RFC 8291 + 8292)
# Generate with: node scripts/generate-vapid-keys.mjs
# In production set VAPID_PRIVATE_KEY and WEEKLY_PUSH_SECRET via `wrangler secret put`.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:team@synapse.study"
WEEKLY_PUSH_SECRET=""
